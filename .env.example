# ============================================================
# Quotra - Decentralized P2P AI API Marketplace
# Copy this to .env.local and fill in missing values
# ============================================================

# --- Supabase (Project: quotra) ---
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Encryption Key (for provider API keys in DB) ---
# Generate with: node -e "const { randomBytes } = require('crypto'); console.log(randomBytes(32).toString('base64'))"
QUOTRA_ENCRYPTION_KEY=your-base64-32-byte-key-here

# --- WalletConnect ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id-here

# --- 1Shot Dev Platform (OAuth2 M2M) ---
# Get these from https://app.1shotapi.com/api-keys
ONE_SHOT_API_CLIENT_ID=your-oneshot-client-id
ONE_SHOT_API_CLIENT_SECRET=your-oneshot-client-secret
ONE_SHOT_API_BUSINESS_ID=your-oneshot-business-id
ONE_SHOT_API_TREASURY_WALLET_ID=your-treasury-wallet-id

# USDC transfer method registered in 1Shot Dev Platform
# Create at: https://app.1shotapi.com/methods
ONE_SHOT_API_USDC_CONTRACT_METHOD_ID=method-id-for-usdc-transfer

# --- 1Shot Public Relayer (Gas Abstraction) ---
# Default: https://relayer.1shotapi.dev/relayers (testnet)
ONE_SHOT_RELAYER_URL=https://relayer.1shotapi.dev/relayers

# --- Base Sepolia ---
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# MetaMask Facilitator untuk Base Sepolia (digunakan bersama x402ExactEvmErc7710ServerScheme)
X402_FACILITATOR_URL=https://tx-sentinel-base-sepolia.api.cx.metamask.io/platform/v2/x402
NEXT_PUBLIC_PAY_TO_ADDRESS=

# --- MetaMask Smart Accounts ---
# Get from: https://docs.pimlico.io/infra/rpc
NEXT_PUBLIC_PIMLICO_API_KEY=your-pimlico-api-key

# --- Base Sepolia USDC ---
# Official USDC on Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# --- JWT (from Supabase Dashboard → Project Settings → API → JWT Settings) ---
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# --- Upstash Redis (Rate Limiting) ---
# Get from: https://console.upstash.com/redis (create free tier database)
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
