# ============================================================
# Quotra - Decentralized P2P AI API Marketplace
# Copy this to .env.local and fill in missing values
# ============================================================

# --- Supabase (Project: quotra) ---
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Encryption Key (for provider API keys in DB) ---
# Generate with: node -e "const { randomBytes } = require('crypto'); console.log(randomBytes(32).toString('base64'))"
QUOTRA_ENCRYPTION_KEY=your-base64-32-byte-key-here

# --- WalletConnect ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-project-id-here

# --- 1Shot Relayer ---
ONE_SHOT_API_KEY=your-1shot-key

# --- Base Sepolia ---
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- x402 ---
X402_FACILITATOR_URL=https://x402.facilitator.coinbase.com
NEXT_PUBLIC_PAY_TO_ADDRESS=

# --- MetaMask Smart Accounts ---
# Get from: https://docs.pimlico.io/infra/rpc
NEXT_PUBLIC_PIMLICO_API_KEY=your-pimlico-api-key

# --- Base Sepolia USDC ---
# Official USDC on Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# --- JWT ---
JWT_SECRET=your-jwt-secret-here

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
